-- OPTIMIZACIÓN AGRESIVA BASE
local settings = settings()
if settings and settings.Rendering then
    settings.Rendering.QualityLevel = Enum.QualityLevel.Level01
    settings.Rendering.MeshPartDetailLevel = Enum.MeshPartDetailLevel.Level01
end

local lighting = game:GetService("Lighting")
lighting.GlobalShadows = false
lighting.FogEnd = 9e9
for _, effect in pairs(lighting:GetChildren()) do
    if effect:IsA("PostEffect") or effect:IsA("BloomEffect") or effect:IsA("BlurEffect") or effect:IsA("DepthOfFieldEffect") or effect:IsA("SunRaysEffect") then
        effect.Enabled = false
    end
end

local function killEverything(object)
    if object:IsA("Texture") or object:IsA("Decal") or object:IsA("Sky") or object:IsA("ParticleEmitter") or object:IsA("Sparkles") or object:IsA("Smoke") or object:IsA("Fire") then
        object:Destroy()
    elseif object:IsA("BasePart") or object:IsA("MeshPart") or object:IsA("CornerWedgePart") or object:IsA("WedgePart") then
        object.Material = Enum.Material.SmoothPlastic
        object.Color = Color3.fromRGB(130, 130, 130) -- Todo gris para no cargar colores pesados
    elseif object:IsA("Clothing") or object:IsA("ShirtGraphic") then
        object:Destroy()
    end
end

for _, object in pairs(workspace:GetDescendants()) do killEverything(object) end
workspace.DescendantAdded:Connect(function(object) killEverything(object) end)

-- BOTÓN EXTREMO: QUITAR RESOLUCIÓN 3D (LITERALMENTE PIXELS)
ExtremePotatoBtn.MouseButton1Click:Connect(function()
    ExtremePotatoBtn.BackgroundColor3 = Color3.fromRGB(0, 150, 0)
    ExtremePotatoBtn.Text = "MODO ULTRA POTATO ACTIVADO"
    
    -- Forzar a la cámara a renderizar en la resolución más baja posible de Roblox
    local settings = settings()
    if settings and settings.Rendering then
        pcall(function()
            settings.Rendering.QualityLevel = Enum.QualityLevel.Level01
        end)
    end
    
    -- Borrar efectos pesados del mapa que queden ocultos
    for _, v in pairs(workspace:GetDescendants()) do
        if v:IsA("PostEffect") or v:IsA("Explosion") then
            v:Destroy()
        end
    end
end)
