-- FUNCIÓN DE LIMPIEZA TOTAL DE TEXTURAS, CUELLOS DE BOTELLA Y MAPA
local function desmantelarObjeto(object)
    -- Eliminar texturas, calcomanías, partículas, estelas y efectos ópticos
    if object:IsA("Texture") or object:IsA("Decal") or object:IsA("ParticleEmitter") or object:IsA("Trail") or object:IsA("SelectionBox") or object:IsA("UIStroke") then
        object:Destroy()
    
    -- Forzar mallas 3D y partes físicas a cajas planas y grises sin texturas internas
    elseif object:IsA("BasePart") or object:IsA("MeshPart") or object:IsA("SpecialMesh") then
        pcall(function()
            if object:IsA("MeshPart") or object:IsA("SpecialMesh") then
                -- Si tiene una ID de textura incrustada en la malla, se la borramos para dejarla en blanco
                object.TextureID = "" 
            end
            object.Material = Enum.Material.SmoothPlastic -- Plástico liso mate
            object.Color = Color3.fromRGB(90, 90, 90)     -- Gris neutral plano
            object.Reflectance = 0                        -- Quitar reflejo de luces
            object.CastShadow = false                     -- Desactivar cálculo de sombras
        end)
        
    -- Quitar ropa pesada de otros jugadores que sature la memoria
    elseif object:IsA("Clothing") or object:IsA("ShirtGraphic") then
        object:Destroy()
    end
end

-- Ejecutar barrido inicial al encender el script
for _, object in pairs(workspace:GetDescendants()) do 
    desmantelarObjeto(object) 
end

-- Monitoreo constante para que todo lo nuevo que cargue pierda resolución al instante
workspace.DescendantAdded:Connect(function(object) 
    desmantelarObjeto(object) 
end)

-- CONTROL INTEGRAL DE RENDIMIENTO DEL MOTOR GRÁFICO
local settings = settings()
if settings and settings.Rendering then
    pcall(function()
        settings.Rendering.QualityLevel = Enum.QualityLevel.Level01
        settings.Rendering.MeshPartDetailLevel = Enum.MeshPartDetailLevel.Level01
    end)
end

-- Apagar sombras globales e iluminación dinámica en el mapa
local lighting = game:GetService("Lighting")
lighting.GlobalShadows = false
lighting.FogEnd = 9e9
for _, effect in pairs(lighting:GetChildren()) do
    if effect:IsA("PostEffect") or effect:IsA("BloomEffect") or effect:IsA("BlurEffect") or effect:IsA("DepthOfFieldEffect") or effect:IsA("SunRaysEffect") then
        effect.Enabled = false
    end
end

-- ACCIÓN DEL BOTÓN AGRESIVO: ELIMINACIÓN DE MAPA EXTRA / ADORNOS DE PARED
ExtremePotatoBtn.MouseButton1Click:Connect(function()
    ExtremePotatoBtn.BackgroundColor3 = Color3.fromRGB(40, 40, 40)
    ExtremePotatoBtn.Text = "MODO APAGÓN TOTAL ACTIVADO"
    ExtremePotatoBtn.TextColor3 = Color3.fromRGB(150, 150, 150)
    
    -- Borrar de raíz carpetas de adornos pesados que suelen estar en el Workspace
    pcall(function()
        for _, v in pairs(workspace:GetDescendants()) do
            -- Si el objeto se llama igual a decoraciones comunes del mapa, lo elimina
            if v.Name:lower():find("candy") or v.Name:lower():find("sweet") or v.Name:lower():find("adorn") or v.Name:lower():find("decor") then
                v:Destroy()
            end
            if v:IsA("BasePart") then
                v.Material = Enum.Material.SmoothPlastic
                v.Color = Color3.fromRGB(60, 60, 60)
            end
        end
    </pcall>
end)-- CREACIÓN DE LA INTERFAZ ULTRA-POTATO COMPACTA Y CERRABLE
